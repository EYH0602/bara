{
  "nodes": [
    {
      "id": "N01",
      "kind": "question",
      "label": "Can a growing NN scale to many CRL tasks while retaining full plasticity?",
      "support_level": null,
      "source_refs": [],
      "description": "Prior growing NN approaches (ProgressiveNet) grow quadratically in parameters, and methods that control growth (PackNet, DEN) sacrifice plasticity. Can we design an architecture that avoids catastrophic forgetting, grows linearly, and maintains full plasticity for each new task?\n",
      "fields": "question",
      "evidence_notes": []
    },
    {
      "id": "N02",
      "kind": "experiment",
      "label": "Test hidden-layer sharing for knowledge transfer (ProgressiveNet style)",
      "support_level": null,
      "source_refs": [],
      "description": null,
      "fields": {
        "experiment": {
          "result": "Lateral connections between hidden layers of all previous columns and the new column cause quadratic parameter growth O(n^2). At 100 tasks, memory and inference time become prohibitive.\n"
        }
      },
      "evidence_notes": [
        "Figure 3",
        "Figure B.1",
        "Appendix C.2",
        "Rusu et al. 2016"
      ]
    },
    {
      "id": "N03",
      "kind": "dead_end",
      "label": "Hidden-layer lateral connections cause quadratic growth — abandoned",
      "support_level": null,
      "source_refs": [],
      "description": null,
      "fields": {
        "dead_end": {
          "hypothesis": "Sharing hidden representations allows rich knowledge transfer with manageable cost",
          "failure_mode": "Each new column must connect to all previous columns' hidden layers, making the key matrix size scale with (number_of_tasks × hidden_size), yielding O(n^2) total parameters and inference cost.\n",
          "lesson": "Knowledge transfer must happen at a fixed-size interface independent of the number of previous modules. Output vectors (action distributions) have constant size |A| regardless of the number of tasks — this is the key insight.\n",
          "why_failed": null
        }
      },
      "evidence_notes": []
    },
    {
      "id": "N04",
      "kind": "experiment",
      "label": "Test compositional approaches with dedicated composer NN",
      "support_level": null,
      "source_refs": [],
      "description": null,
      "fields": {
        "experiment": {
          "result": "Joint training of composer and composed modules is non-stationary: the composing strategy depends on optimizing the modules, and vice versa. Training is unstable.\n"
        }
      },
      "evidence_notes": [
        "Rosenbaum et al. 2019",
        "Khetarpal et al. 2022",
        "Section 2"
      ]
    },
    {
      "id": "N05",
      "kind": "dead_end",
      "label": "Dedicated composer network causes training instability — abandoned",
      "support_level": null,
      "source_refs": [],
      "description": null,
      "fields": {
        "dead_end": {
          "hypothesis": "A separate router/composer NN can learn to compose specialized modules",
          "failure_mode": "The composing strategy depends on the state of the modules being composed, and module optimization depends on the composing strategy, creating a non-stationary learning problem that is difficult to stabilize.\n",
          "lesson": "Composition must be self-contained within each module — no external coordinator. Each module should autonomously learn how to combine previous outputs.\n",
          "why_failed": null
        }
      },
      "evidence_notes": []
    },
    {
      "id": "N06",
      "kind": "decision",
      "label": "Choose output-level composition via attention as the key design",
      "support_level": null,
      "source_refs": [],
      "description": null,
      "fields": {
        "decision": {
          "choice": "Each new module receives the output action vectors of all previous modules (the Phi matrix) and uses attention conditioned on the current state to selectively combine them. No dedicated composer needed.\n",
          "alternatives": [
            "Hidden-layer lateral connections (ProgressiveNet style): O(n^2) growth",
            "External routing network: training instability",
            "Subspace of policies (Gaya et al. 2023): shared parameter space"
          ],
          "rationale": null
        }
      },
      "evidence_notes": [
        "Output vectors have constant size |A| per module, so the Phi matrix grows in rows (k-1) but not in columns, and attention weight matrices W_Q, W_K have sizes depending only on d_enc, |A|, d_model — all constants.\n"
      ]
    },
    {
      "id": "N07",
      "kind": "experiment",
      "label": "Verify linear parameter growth of output-level composition",
      "support_level": null,
      "source_refs": [],
      "description": null,
      "fields": {
        "experiment": {
          "result": "Each self-composing module has exactly 6 linear transformations and a feed-forward block with sizes depending only on fixed d_enc, d_model, |A|. Total parameters grow as O(m*n) where m is constant per module.\n"
        }
      },
      "evidence_notes": [
        "Appendix B",
        "Figure B.1",
        "Figure 3 (right)"
      ]
    },
    {
      "id": "N08",
      "kind": "experiment",
      "label": "Measure empirical inference time vs task count (up to 300)",
      "support_level": null,
      "source_refs": [],
      "description": null,
      "fields": {
        "experiment": {
          "result": "Despite O(n^2) theoretical complexity, CompoNet's empirical inference time grows substantially slower than ProgressiveNet up to 300 tasks due to parallel attention computation within each module.\n"
        }
      },
      "evidence_notes": [
        "Figure 3 (left)",
        "Figure C.1",
        "Appendix C.2"
      ]
    },
    {
      "id": "N09",
      "kind": "experiment",
      "label": "Validate three-scenario robustness (reuse, compose, scratch)",
      "support_level": null,
      "source_refs": [],
      "description": null,
      "fields": {
        "experiment": {
          "result": "(i) When an informative prior module exists, OutputAttentionHead rapidly assigns attention~1.0 to it; InternalPolicy converges to mimic its output. (iii) When all priors are non-informative, InternalPolicy dominates and CompoNet matches baseline performance with no interference.\n"
        }
      },
      "evidence_notes": [
        "Figure 4",
        "Section 5.4"
      ]
    },
    {
      "id": "N10",
      "kind": "experiment",
      "label": "Ablate Output Attention Head on Freeway sequence",
      "support_level": null,
      "source_refs": [],
      "description": null,
      "fields": {
        "experiment": {
          "result": "Removing Output Attention Head causes significant performance degradation on Freeway (sparse reward: policy reuse critical) but minimal impact on SpaceInvaders (denser reward: internal policy sufficient).\n"
        }
      },
      "evidence_notes": [
        "Figure G.1",
        "Appendix G.1"
      ]
    },
    {
      "id": "N11",
      "kind": "experiment",
      "label": "Ablate Input Attention Head — shifted informative module",
      "support_level": null,
      "source_refs": [],
      "description": null,
      "fields": {
        "experiment": {
          "result": "Without the Input Attention Head, CompoNet cannot extract useful signal from a shifted informative module (direct imitation blocked); performance matches baseline. Original CompoNet significantly outperforms.\n"
        }
      },
      "evidence_notes": [
        "Figure G.2",
        "Appendix G.2"
      ]
    },
    {
      "id": "N12",
      "kind": "experiment",
      "label": "Main benchmark: CompoNet vs 5 baselines on 3 task sequences",
      "support_level": null,
      "source_refs": [],
      "description": null,
      "fields": {
        "experiment": {
          "result": "CompoNet achieves superior or equal performance and forward transfer on all three sequences (Meta-World, SpaceInvaders, Freeway). CompoNet is the only method with non-negative FTr on Meta-World and exceeds RT on all sequences.\n"
        }
      },
      "evidence_notes": [
        "Table 1",
        "Section 5.3",
        "Figures F.1-F.3"
      ]
    }
  ],
